{
  "name": "@ssortia/shadcn-zod-bridge",
  "version": "0.1.0",
  "description": "Declarative form library built on Zod schemas and shadcn/ui components",
  "keywords": [
    "react",
    "form",
    "zod",
    "shadcn",
    "shadcn-ui",
    "react-hook-form",
    "autoform",
    "typescript",
    "validation"
  ],
  "author": "ssortia",
  "license": "MIT",
  "homepage": "https://github.com/ssortia/shadcn-zod-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssortia/shadcn-zod-bridge.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/src/index.d.ts",
  "sideEffects": [
    "dist/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist/*.js",
    "dist/*.mjs",
    "dist/*.css",
    "dist/src/**/*.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "zod": ">=4",
    "tailwindcss": ">=4"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.13.2",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.0.0",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
